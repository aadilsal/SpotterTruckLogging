# Copy to .env and fill in your values before deploying
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1
ORS_API_KEY=your-openrouteservice-api-key

# Render / cloud (optional — Render sets DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@host:5432/eld_planner

# Production CORS (set after Vercel deploy)
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
